# Anthropic API key for Claude-powered analysis
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Open States API key (free at https://openstates.org/accounts/signup/)
# When set, the crawler uses the Open States REST API for state legislators
# instead of browser-based crawling (faster, more reliable).
OPENSTATES_API_KEY=

# LegiScan API key (free at https://legiscan.com/legiscan)
# Primary source for bill tracking across all 50 states + Congress.
# Free tier: 30,000 requests per 30-day rolling window.
LEGISCAN_API_KEY=
